# =============================================================================
# Metaculus 预测 bot 环境变量
#
# 本地运行：复制本文件为 .env，把每个 REPLACE_ME 换成你的真实 key。
#   cp .env.example .env
#
# GitHub Actions 运行：不要提交 .env！而是在
#   Settings → Secrets and variables → Actions → New repository secret
# 里逐个添加（变量名必须完全一致，全大写）。
# =============================================================================


# ---- 必填 ---------------------------------------------------------------------
# 你的 Metaculus bot 账号 token。没有它 bot 无法读题/提交预测。
# 获取：https://www.metaculus.com/futureeval/participate/
# 注意：真实 token 请填到 .env（已被 gitignore），不要填在本模板文件里！
METACULUS_TOKEN=REPLACE_ME


# ---- LLM 提供方 ----------------------------------------------------------------
# 重要：AIB 比赛期间 Metaculus 通过 `metaculus/` 代理免费提供 LLM 调用。
# 本 bot 默认就用这个代理（见 main.py 顶部 FORECASTER_MODELS），
# 所以只要有 METACULUS_TOKEN 就能零成本跑起来，下面这些都是“可选增强”。
#
# 想用自己的 OpenRouter key（一个 key 通多家模型，比赛也送免费额度）时再填：
#   免费额度表单：https://forms.gle/aQdYMq9Pisrf1v7d8
#   申请 key：    https://openrouter.ai/keys
# OPENROUTER_API_KEY=REPLACE_ME

# 其它可选 LLM key（填了就能在 FORECASTER_MODELS 里用对应模型）
# OPENAI_API_KEY=REPLACE_ME
# ANTHROPIC_API_KEY=REPLACE_ME


# ---- 搜索 / 资讯提供方（全部可选，但强烈建议至少配一个）-------------------------------
# 研究质量直接影响排名。都不配时 bot 会退化为“仅靠 LLM 自身知识”做研究。
#
# AskNews（首选）：https://asknews.app/  —— 比赛期间通常有赞助额度。
#   ★ 一旦填了下面的 CLIENT_ID + SECRET（或 ASKNEWS_API_KEY），bot 会自动启用
#     DeepNews 深度研究（多轮检索+推理、带引用），研究质量远高于普通新闻检索。
#     深度/成本可在 main.py 顶部的 ASKNEWS_DEEP_* 常量里调。
# ASKNEWS_CLIENT_ID=REPLACE_ME
# ASKNEWS_SECRET=REPLACE_ME
# 或者用单一 API key（与上面的 CLIENT_ID/SECRET 二选一）：
# ASKNEWS_API_KEY=REPLACE_ME
#
# Exa（给 SmartSearcher 用）：https://exa.ai/
# EXA_API_KEY=REPLACE_ME
#
# Perplexity：https://docs.perplexity.ai/
# PERPLEXITY_API_KEY=REPLACE_ME
